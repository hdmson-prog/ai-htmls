<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set the base directory for rewrites
    RewriteBase /hrm/
    
    # Allow direct access to actual files
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
    
    # Allow direct access to actual directories
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Exclude /assets/ folder from rewrite
    RewriteRule ^assets/ - [L]
    
    # Exclude /uploads/ folder from rewrite
    RewriteRule ^uploads/ - [L]
    
    # Rewrite all other requests to index.php with url parameter
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>

# Prevent access to sensitive files
<FilesMatch "\.php$">
    Order allow,deny
    Allow from all
</FilesMatch>
